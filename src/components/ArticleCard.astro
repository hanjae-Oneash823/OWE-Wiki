---
import { getNoteSlug } from '../content.config';
import type { CollectionEntry } from 'astro:content';

interface Props {
  note: CollectionEntry<'notes'>;
}

const { note } = Astro.props;
const href = `/notes/${note.data.domain}/${getNoteSlug(note.id, note.data.domain)}`;
const dateLabel = note.data.publishedDate.toISOString().slice(0, 10);
---

<a class="article-card" href={href}>
  <div class={`article-card__image ${note.data.image ? 'article-card__image--cover' : ''}`}>
    {note.data.image ? (
      <img src={note.data.image} alt="" loading="lazy" />
    ) : (
      <div class="article-card__placeholder" aria-hidden="true"></div>
    )}
  </div>
  <span class="article-card__date">{dateLabel}</span>
  <span class="article-card__title">{note.data.title}</span>
  <span class="article-card__domain">{note.data.domain}</span>
</a>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-decoration: none;
    color: var(--color-fg);
  }

  .article-card__image {
    aspect-ratio: 1 / 1;
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .article-card__image--cover {
    border-color: #000;
  }

  .article-card__image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-card__placeholder {
    width: 100%;
    height: 100%;
    background:
      repeating-linear-gradient(
        45deg,
        var(--color-border) 0,
        var(--color-border) 1px,
        transparent 1px,
        transparent 10px
      );
  }

  .article-card__date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
  }

  .article-card__title {
    font-family: var(--font-display);
    font-weight: 500;
    line-height: 1.25;
  }

  .article-card:hover .article-card__title {
    color: var(--brand-red);
  }

  .article-card__domain {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-muted);
  }
</style>
