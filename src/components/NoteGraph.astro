---
import type { CollectionEntry } from 'astro:content';
import { getNoteSlug } from '../lib/noteSlug';

interface Props {
  note: CollectionEntry<'notes'>;
  outbound: CollectionEntry<'notes'>[];
  backlinks: CollectionEntry<'notes'>[];
}

type Relation = 'both' | 'outbound' | 'backlink';

interface NeighborNode {
  note: CollectionEntry<'notes'>;
  relation: Relation;
}

const MAX_NEIGHBORS = 8;
const SIZE = 420;
const CENTER = SIZE / 2;
const ORBIT_RADIUS = 150;
const NODE_RADIUS = 8;
const CENTER_NODE_RADIUS = 11;

const { note, outbound, backlinks } = Astro.props;

const neighborMap = new Map<string, NeighborNode>();
for (const n of outbound) neighborMap.set(n.id, { note: n, relation: 'outbound' });
for (const n of backlinks) {
  const existing = neighborMap.get(n.id);
  neighborMap.set(n.id, { note: n, relation: existing ? 'both' : 'backlink' });
}

const allNeighbors = [...neighborMap.values()].sort((a, b) => a.note.data.title.localeCompare(b.note.data.title));
const neighbors = allNeighbors.slice(0, MAX_NEIGHBORS);
const overflowCount = allNeighbors.length - neighbors.length;

function positionFor(index: number, total: number): { x: number; y: number } {
  const angle = (index / total) * Math.PI * 2 - Math.PI / 2;
  return { x: CENTER + ORBIT_RADIUS * Math.cos(angle), y: CENTER + ORBIT_RADIUS * Math.sin(angle) };
}

function truncateTitle(title: string, max = 22): string {
  return title.length > max ? `${title.slice(0, max - 1)}…` : title;
}
---

{neighbors.length === 0 ? (
  <p class="note-graph-empty">No linked notes yet.</p>
) : (
  <div class="note-graph">
    <svg viewBox={`0 0 ${SIZE} ${SIZE}`} role="img" aria-label={`Notes linked to ${note.data.title}`}>
      {neighbors.map((neighbor, index) => {
        const pos = positionFor(index, neighbors.length);
        return (
          <line
            x1={CENTER}
            y1={CENTER}
            x2={pos.x}
            y2={pos.y}
            class:list={['note-graph__edge', { 'note-graph__edge--backlink': neighbor.relation === 'backlink' }]}
          />
        );
      })}

      <circle cx={CENTER} cy={CENTER} r={CENTER_NODE_RADIUS} class="note-graph__node note-graph__node--center" />
      <text x={CENTER} y={CENTER + CENTER_NODE_RADIUS + 16} class="note-graph__label note-graph__label--center" text-anchor="middle">
        {truncateTitle(note.data.title)}
      </text>

      {neighbors.map((neighbor, index) => {
        const pos = positionFor(index, neighbors.length);
        const href = `/notes/${neighbor.note.data.domain}/${getNoteSlug(neighbor.note.id, neighbor.note.data.domain)}`;
        const labelY = pos.y > CENTER ? pos.y + NODE_RADIUS + 14 : pos.y - NODE_RADIUS - 8;
        return (
          <a href={href} class="note-graph__neighbor">
            <circle cx={pos.x} cy={pos.y} r={NODE_RADIUS} class="note-graph__node" />
            <text x={pos.x} y={labelY} class="note-graph__label" text-anchor="middle">
              {truncateTitle(neighbor.note.data.title)}
            </text>
          </a>
        );
      })}
    </svg>

    {overflowCount > 0 && (
      <p class="note-graph-overflow">+{overflowCount} more linked note{overflowCount === 1 ? '' : 's'}</p>
    )}
  </div>
)}

<style>
  .note-graph {
    margin: 1rem 0;
  }

  .note-graph svg {
    width: 100%;
    max-width: 420px;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .note-graph__edge {
    stroke: var(--color-accent);
    stroke-width: 1.5;
  }

  .note-graph__edge--backlink {
    stroke: var(--color-muted);
    stroke-dasharray: 4 3;
  }

  .note-graph__node {
    fill: var(--color-bg);
    stroke: var(--color-fg);
    stroke-width: 1.5;
  }

  .note-graph__node--center {
    fill: var(--color-fg);
  }

  .note-graph__neighbor .note-graph__node {
    transition: fill 0.15s ease, stroke 0.15s ease;
  }

  .note-graph__neighbor:hover .note-graph__node {
    fill: var(--color-accent);
    stroke: var(--color-accent);
  }

  .note-graph__neighbor:hover .note-graph__label {
    fill: var(--color-accent);
  }

  .note-graph__label {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--color-muted);
  }

  .note-graph__label--center {
    fill: var(--color-fg);
    font-weight: 700;
  }

  .note-graph-overflow,
  .note-graph-empty {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    text-align: center;
    margin: 0.5rem 0 0;
  }
</style>
