---
import GrowthBadge from './GrowthBadge.astro';
import { getNoteSlug } from '../content.config';
import type { CollectionEntry } from 'astro:content';

interface Props {
  note: CollectionEntry<'notes'>;
  showDomain?: boolean;
}

const { note, showDomain = true } = Astro.props;
const href = `/notes/${note.data.domain}/${getNoteSlug(note.id, note.data.domain)}`;
const dateLabel = note.data.publishedDate.toISOString().slice(0, 10);
---

<li class="note-row">
  <span class="note-row__date">{dateLabel}</span>
  <GrowthBadge stage={note.data.growthStage} />
  <a class="note-row__title" href={href}>{note.data.title}</a>
  {showDomain && <span class="note-row__domain">{note.data.domain}</span>}
</li>

<style>
  .note-row {
    display: grid;
    grid-template-columns: 6.5rem 6.5rem 1fr auto;
    align-items: baseline;
    gap: 1rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .note-row__date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .note-row__title {
    font-family: var(--font-display);
    font-weight: 500;
    text-decoration: none;
    color: var(--color-fg);
  }

  .note-row__title:hover {
    color: var(--color-accent);
  }

  .note-row__domain {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  @media (max-width: 640px) {
    .note-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>
