---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

const initialQuery = Astro.url.searchParams.get('q') ?? '';
---

<BaseLayout title="Search — Knowledge Wiki">
  <h1>Search</h1>
  <input
    type="search"
    id="search-input"
    class="search-input"
    placeholder="Search notes…"
    autocomplete="off"
    value={initialQuery}
  />
  <p id="search-status" class="search-status"></p>
  <ul id="search-results" class="search-results"></ul>
</BaseLayout>

<script is:inline>
  const input = document.getElementById('search-input');
  const status = document.getElementById('search-status');
  const results = document.getElementById('search-results');

  let debounceHandle;
  let pagefindPromise;

  function loadPagefind() {
    if (!pagefindPromise) {
      pagefindPromise = import('/pagefind/pagefind.js').then(async (mod) => {
        await mod.init();
        return mod;
      });
    }
    return pagefindPromise;
  }

  async function runSearch(query) {
    results.replaceChildren();

    if (!query.trim()) {
      status.textContent = '';
      return;
    }

    status.textContent = 'Searching…';

    try {
      const pagefind = await loadPagefind();
      const search = await pagefind.search(query);

      if (search.results.length === 0) {
        status.textContent = `No results for "${query}"`;
        return;
      }

      status.textContent = `${search.results.length} result${search.results.length === 1 ? '' : 's'} for "${query}"`;

      for (const result of search.results) {
        const data = await result.data();
        const li = document.createElement('li');
        li.className = 'search-row';

        const link = document.createElement('a');
        link.className = 'search-row__title';
        link.href = data.url;
        link.textContent = data.meta?.title ?? data.url;

        const excerpt = document.createElement('p');
        excerpt.className = 'search-row__excerpt';
        excerpt.innerHTML = data.excerpt;

        li.append(link, excerpt);
        results.append(li);
      }
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Unknown error';
      status.textContent = `Search failed: ${message}`;
      console.error('Pagefind search failed', error);
    }
  }

  input?.addEventListener('input', () => {
    clearTimeout(debounceHandle);
    const query = input.value;
    debounceHandle = setTimeout(() => runSearch(query), 150);
  });

  if (input?.value) {
    runSearch(input.value);
  }
</script>

<style>
  .search-input {
    width: 100%;
    font-family: var(--font-body);
    font-size: 1.1rem;
    padding: 0.6rem 0.75rem;
    background: var(--color-bg);
    color: var(--color-fg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .search-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
  }

  .search-status {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    margin: 0.75rem 0;
  }

  .search-results {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .search-row {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .search-row__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.05rem;
    text-decoration: none;
    color: var(--color-fg);
  }

  .search-row__title:hover {
    color: var(--color-accent);
  }

  .search-row__excerpt {
    margin: 0.3rem 0 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .search-row__excerpt :global(mark) {
    background: none;
    color: var(--color-accent);
    font-weight: 700;
  }
</style>
