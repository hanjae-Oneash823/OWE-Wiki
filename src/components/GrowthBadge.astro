---
interface Props {
  stage: 'seedling' | 'sprout' | 'established';
}

const { stage } = Astro.props;
---

<span class="growth-tag">[{stage}]</span>

<style>
  .growth-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }
</style>
