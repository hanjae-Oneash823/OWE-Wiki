---
import 'katex/dist/katex.min.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A living knowledge base for coding, bioinformatics, biology, and ML/DL/AI.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Alegreya+Sans:ital,wght@0,400;0,500;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">Knowledge Wiki</a>
      <nav>
        <a href="/domain/coding">Coding</a>
        <a href="/domain/bioinformatics">Bioinformatics</a>
        <a href="/domain/biology">Biology</a>
        <a href="/domain/ml-dl-ai">ML/DL/AI</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Growth-stage knowledge base &mdash; seedlings welcome.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --color-bg: #fdfdfb;
    --color-fg: #17181a;
    --color-muted: #6e7075;
    --color-border: #d9d9d4;
    --color-accent: #2f6f4f;

    --font-display: 'Alegreya Sans', sans-serif;
    --font-body: 'Alegreya Sans', sans-serif;
    --font-mono: ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace;

    --radius: 0;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-bg: #121314;
      --color-fg: #ececea;
      --color-muted: #9a9c9f;
      --color-border: #2b2d30;
      --color-accent: #4a9e73;
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1.05rem;
    background: var(--color-bg);
    color: var(--color-fg);
    line-height: 1.6;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .site-title {
    font-family: var(--font-display);
    font-weight: 800;
    text-decoration: none;
    color: var(--color-fg);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.95rem;
  }

  .site-header nav {
    display: flex;
    gap: 1.5rem;
  }

  .site-header nav a {
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .site-header nav a:hover {
    color: var(--color-fg);
  }

  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem;
  }

  .site-footer {
    text-align: center;
    padding: 2rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  a {
    color: var(--color-accent);
  }

  code {
    background: color-mix(in srgb, var(--color-fg) 8%, transparent);
    padding: 0.15em 0.35em;
    border-radius: var(--radius);
    font-size: 0.9em;
  }

  pre code {
    background: none;
    padding: 0;
  }
</style>
