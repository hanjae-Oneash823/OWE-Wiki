---
export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDomains } from '../../lib/domains';
import { createSupabaseServerClient } from '../../lib/supabase/server';

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const domains = await getDomains(supabase);

const notes = await getCollection('notes');
const domainCounts = Object.fromEntries(
  domains.map(({ slug }) => [slug, notes.filter((note) => note.data.domain === slug).length])
);
---

<BaseLayout title="Domains — Knowledge Wiki">
  <p><a href="/">&larr; Home</a></p>
  <h1>Domains</h1>

  <ul class="domain-list">
    {domains.map(({ slug, description }) => (
      <li class="domain-card">
        <a href={`/domain/${slug}`}>
          <span class="domain-card-title">{slug}</span>
          <span class="domain-card-count">{String(domainCounts[slug]).padStart(2, '0')}</span>
        </a>
        {description && <p class="domain-card-description">{description}</p>}
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .domain-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    gap: 1.25rem;
  }

  .domain-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .domain-card a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    text-decoration: none;
  }

  .domain-card-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 500;
    text-transform: capitalize;
    color: var(--color-fg);
  }

  .domain-card a:hover .domain-card-title {
    color: var(--color-accent);
  }

  .domain-card-count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .domain-card-description {
    margin: 0.4rem 0 0;
    color: var(--color-muted);
    max-width: 60ch;
  }
</style>
