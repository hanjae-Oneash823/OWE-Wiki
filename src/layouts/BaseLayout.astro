---
import 'katex/dist/katex.min.css';
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A living knowledge base for coding, bioinformatics, biology, and ML/DL/AI.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Alegreya+Sans:ital,wght@0,400;0,500;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">
        <Image src={logo} alt="OWE wiki" height={48} />
      </a>
      <nav>
        <a href="/domain/coding">Coding</a>
        <a href="/domain/bioinformatics">Bioinformatics</a>
        <a href="/domain/biology">Biology</a>
        <a href="/domain/ml-dl-ai">ML/DL/AI</a>
        <a href="/search">Search</a>
        <a id="write-link" href="/write" hidden>Write</a>
        <span id="auth-status" class="auth-status"></span>
      </nav>
    </header>
    <main data-pagefind-body>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Growth-stage knowledge base &mdash; seedlings welcome.</p>
    </footer>
  </body>
</html>

<script>
  import { createBrowserClient } from '@supabase/ssr';

  const supabase = createBrowserClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
  const authStatus = document.getElementById('auth-status');

  function renderLoginButton() {
    if (!authStatus) return;
    const loginButton = document.createElement('button');
    loginButton.type = 'button';
    loginButton.className = 'auth-link';
    loginButton.textContent = 'Log in';
    loginButton.addEventListener('click', () => {
      supabase.auth.signInWithOAuth({
        provider: 'github',
        options: { redirectTo: `${window.location.origin}/auth/callback` },
      });
    });
    authStatus.replaceChildren(loginButton);
  }

  async function renderAuthStatus() {
    if (!authStatus) return;

    try {
      const response = await fetch('/api/session');
      if (!response.ok) throw new Error(`Session check failed: ${response.status}`);
      const { user } = await response.json();

      if (!user) {
        renderLoginButton();
        return;
      }

      const writeLink = document.getElementById('write-link');
      if (writeLink && (user.role === 'writer' || user.role === 'admin')) {
        writeLink.removeAttribute('hidden');
      }

      const username = document.createElement('span');
      username.className = 'auth-username';
      username.textContent = user.username ?? 'Account';

      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '/logout';
      const logoutButton = document.createElement('button');
      logoutButton.type = 'submit';
      logoutButton.className = 'auth-link';
      logoutButton.textContent = 'Log out';
      form.append(logoutButton);

      authStatus.replaceChildren(username, form);
    } catch (error) {
      console.error('Failed to load auth status', error);
      renderLoginButton();
    }
  }

  renderAuthStatus();
</script>

<style is:global>
  :root {
    color-scheme: light dark;
    --color-bg: #fdfdfb;
    --color-fg: #17181a;
    --color-muted: #6e7075;
    --color-border: #d9d9d4;
    --color-accent: #2f6f4f;
    --brand-red: #d8402c;
    --brand-dark-red: #93201e;

    --font-display: 'Alegreya Sans', sans-serif;
    --font-body: 'Alegreya Sans', sans-serif;
    --font-mono: ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace;

    --radius: 0;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-bg: #121314;
      --color-fg: #ececea;
      --color-muted: #9a9c9f;
      --color-border: #2b2d30;
      --color-accent: #4a9e73;
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1.05rem;
    background: var(--color-bg);
    color: var(--color-fg);
    line-height: 1.6;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .site-title {
    display: flex;
    align-items: center;
    line-height: 0;
  }

  .site-title img {
    display: block;
    width: auto;
    height: 48px;
  }

  .site-header nav {
    display: flex;
    gap: 1.5rem;
  }

  .site-header nav a {
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .site-header nav a:hover {
    color: var(--color-fg);
  }

  .auth-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .auth-username {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .auth-link {
    font-family: inherit;
    background: none;
    border: none;
    padding: 0;
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
  }

  .auth-link:hover {
    color: var(--color-fg);
  }

  main {
    max-width: 1040px;
    margin: 0 auto;
    padding: 2rem;
  }

  .site-footer {
    text-align: center;
    padding: 2rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  a {
    color: var(--color-accent);
  }

  code {
    background: color-mix(in srgb, var(--color-fg) 8%, transparent);
    padding: 0.15em 0.35em;
    border-radius: var(--radius);
    font-size: 0.9em;
  }

  pre code {
    background: none;
    padding: 0;
  }
</style>
