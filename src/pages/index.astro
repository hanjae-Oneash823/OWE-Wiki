---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GrowthBadge from '../components/GrowthBadge.astro';
import { DOMAINS, getNoteSlug } from '../content.config';

const notes = await getCollection('notes');
const recentNotes = [...notes]
  .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf())
  .slice(0, 10);

const domainCounts = Object.fromEntries(
  DOMAINS.map((domain) => [domain, notes.filter((note) => note.data.domain === domain).length])
);
---

<BaseLayout title="Knowledge Wiki">
  <h1>Knowledge Wiki</h1>
  <p>
    A living knowledge base for coding, bioinformatics, biology, and ML/DL/AI &mdash;
    organized by growth stage instead of "finished" status. Seedlings welcome.
  </p>

  <section>
    <h2>Domains</h2>
    <ul class="domain-list">
      {DOMAINS.map((domain) => (
        <li>
          <a href={`/domain/${domain}`}>{domain}</a>
          <span class="count">{domainCounts[domain]}</span>
        </li>
      ))}
    </ul>
  </section>

  <section>
    <h2>Recently updated</h2>
    {recentNotes.length === 0 ? (
      <p>No notes yet &mdash; plant the first seedling.</p>
    ) : (
      <ul class="note-list">
        {recentNotes.map((note) => (
          <li>
            <a href={`/notes/${note.data.domain}/${getNoteSlug(note.id, note.data.domain)}`}>{note.data.title}</a>
            <GrowthBadge stage={note.data.growthStage} />
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .domain-list,
  .note-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .domain-list li,
  .note-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .domain-list a {
    text-transform: capitalize;
    font-weight: 600;
  }

  .count {
    color: var(--color-muted);
    font-size: 0.85rem;
  }
</style>
