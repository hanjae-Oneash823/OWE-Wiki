---
export const prerender = true;

import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import darwinTree from '../assets/darwin-tree.png';
import { DOMAINS } from '../content.config';

const notes = await getCollection('notes');
const recentNotes = [...notes]
  .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf())
  .slice(0, 10);

const domainCounts = Object.fromEntries(
  DOMAINS.map((domain) => [domain, notes.filter((note) => note.data.domain === domain).length])
);

const descendantText =
  'One of four descendant lines Darwin sketched from a shared ancestor — his first attempt at drawing evolution as a branching tree instead of a ladder.';

const heroHotspots = [
  { id: 'root', x: 33.5, y: 87, label: 'The common ancestor', text: 'The common ancestor — every line below traces back to this point.' },
  { id: 'a', x: 79.6, y: 91.7, label: 'Descendant line A', text: descendantText },
  { id: 'b', x: 43.5, y: 29, label: 'Descendant line B', text: descendantText },
  { id: 'c', x: 51.1, y: 38.6, label: 'Descendant line C', text: descendantText },
  { id: 'd', x: 15.5, y: 41, label: 'Descendant line D', text: descendantText },
];
---

<BaseLayout title="One With Everything wiki">
  <section class="hero">
    <div class="hero-text">
      <h1 class="site-name">
        <span class="site-name__owe">One With Everything</span>
        <span class="site-name__wiki">wiki</span>
      </h1>
      <p class="hero-tagline">Every note starts as a sketch in a notebook.</p>
      <p class="hero-body">
        An ongoing archive for turning half-formed understanding into knowledge someone else
        can actually use. Every article started as a draft someone worked through in the open.
      </p>
    </div>
    <figure class="hero-figure">
      <div class="hero-figure-frame">
        <Image
          src={darwinTree}
          alt="Charles Darwin's 1837 sketch of a branching tree of life, captioned &quot;I think,&quot; from his First Notebook on Transmutation of Species"
          width={695}
          height={630}
        />
        {heroHotspots.map((spot) => (
          <div class="hotspot-wrap" style={`left:${spot.x}%; top:${spot.y}%`}>
            <button class="hotspot" type="button" aria-label={spot.label}>
              <span aria-hidden="true">+</span>
            </button>
            <span class="hotspot-tooltip" role="tooltip">{spot.text}</span>
          </div>
        ))}
      </div>
      <figcaption>Charles Darwin, Notebook B, 1837<br />the first sketch of the tree of life</figcaption>
    </figure>
  </section>

  <section class="search-strip">
    <form action="/search" method="get" class="search-strip-form">
      <input
        type="search"
        name="q"
        class="search-strip-input"
        placeholder="Search notes…"
        autocomplete="off"
      />
      <button type="submit" class="search-strip-submit">Search</button>
    </form>
  </section>

  <div class="home-grid">
    <section>
      <h2>Domains</h2>
      <ul class="domain-list">
        {DOMAINS.map((domain) => (
          <li class="domain-row">
            <a href={`/domain/${domain}`}>{domain}</a>
            <span class="count">{String(domainCounts[domain]).padStart(2, '0')}</span>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Recently updated</h2>
      {recentNotes.length === 0 ? (
        <p>No articles yet &mdash; write the first draft.</p>
      ) : (
        <div class="article-grid">
          {recentNotes.map((note) => (
            <ArticleCard note={note} />
          ))}
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 3.5rem;
    align-items: center;
    margin-bottom: 3.5rem;
  }

  .site-name {
    font-family: 'Marion', Georgia, serif;
    font-weight: 700;
    font-size: 2.25rem;
    letter-spacing: -0.01em;
  }

  .site-name__owe {
    color: var(--brand-red);
  }

  .site-name__wiki {
    display: inline-block;
    margin-left: 0.35em;
    color: var(--brand-dark-red);
    font-style: italic;
    font-weight: 500;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 1.25rem 0 0.75rem;
  }

  .hero-body {
    color: var(--color-muted);
  }

  .hero-figure {
    margin: 0;
    justify-self: center;
  }

  .hero-figure-frame {
    position: relative;
    width: 100%;
    max-width: 320px;
  }

  .hero-figure-frame img {
    display: block;
    width: 100%;
    height: auto;
    mix-blend-mode: multiply;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-figure-frame img {
      animation: hero-grow 1.4s ease-out both;
    }

    .hotspot-wrap {
      opacity: 0;
      animation: hero-hotspot-in 0.5s ease-out 1.3s both;
    }
  }

  @keyframes hero-grow {
    from {
      clip-path: inset(100% 0 0 0);
    }
    to {
      clip-path: inset(0 0 0 0);
    }
  }

  @keyframes hero-hotspot-in {
    to {
      opacity: 1;
    }
  }

  .hotspot-wrap {
    position: absolute;
    transform: translate(-50%, -50%);
  }

  .hotspot {
    width: 1.1rem;
    height: 1.1rem;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--brand-red);
    background: var(--color-bg);
    color: var(--brand-red);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1;
    cursor: pointer;
  }

  .hotspot:hover,
  .hotspot:focus-visible {
    background: var(--brand-red);
    color: var(--color-bg);
  }

  .hotspot-tooltip {
    position: absolute;
    bottom: 140%;
    left: 50%;
    transform: translateX(-50%);
    width: max-content;
    max-width: 220px;
    padding: 0.5rem 0.65rem;
    background: var(--color-fg);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 0.8rem;
    line-height: 1.4;
    border-radius: var(--radius);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
    z-index: 1;
  }

  .hotspot-wrap:hover .hotspot-tooltip,
  .hotspot:focus-visible + .hotspot-tooltip {
    opacity: 1;
  }

  .hero-figure figcaption {
    margin-top: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    text-align: center;
  }

  @media (max-width: 720px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-figure {
      order: -1;
      max-width: 220px;
      margin: 0 auto;
    }
  }

  .search-strip {
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .search-strip-form {
    display: flex;
    gap: 0.75rem;
  }

  .search-strip-input {
    flex: 1;
    font-family: var(--font-body);
    font-size: 1.1rem;
    padding: 0.6rem 0.75rem;
    background: var(--color-bg);
    color: var(--color-fg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .search-strip-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
  }

  .search-strip-submit {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    background: none;
    border: 1px solid var(--color-fg);
    border-radius: var(--radius);
    padding: 0.4rem 1.2rem;
    color: var(--color-fg);
    cursor: pointer;
  }

  .search-strip-submit:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .home-grid {
    display: grid;
    grid-template-columns: minmax(180px, 220px) 1fr;
    gap: 3rem;
    margin-top: 1rem;
  }

  @media (max-width: 720px) {
    .home-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .domain-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1.5rem;
  }

  .domain-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .domain-row a {
    font-family: var(--font-display);
    font-weight: 500;
    text-transform: capitalize;
    text-decoration: none;
    color: var(--color-fg);
  }

  .domain-row a:hover {
    color: var(--color-accent);
  }

  .count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-muted);
  }
</style>
