---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NoteRow from '../components/NoteRow.astro';
import { DOMAINS } from '../content.config';

const notes = await getCollection('notes');
const recentNotes = [...notes]
  .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf())
  .slice(0, 10);

const domainCounts = Object.fromEntries(
  DOMAINS.map((domain) => [domain, notes.filter((note) => note.data.domain === domain).length])
);
---

<BaseLayout title="One With Everything wiki">
  <h1 class="site-name">
    <span class="site-name__owe">One With Everything</span>
    <span class="site-name__wiki">wiki</span>
  </h1>
  <p>
    A living knowledge base for coding, bioinformatics, biology, and ML/DL/AI &mdash;
    organized by growth stage instead of "finished" status. Seedlings welcome.
  </p>

  <div class="home-grid">
    <section>
      <h2>Domains</h2>
      <ul class="domain-list">
        {DOMAINS.map((domain) => (
          <li class="domain-row">
            <a href={`/domain/${domain}`}>{domain}</a>
            <span class="count">{String(domainCounts[domain]).padStart(2, '0')}</span>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Recently updated</h2>
      {recentNotes.length === 0 ? (
        <p>No notes yet &mdash; plant the first seedling.</p>
      ) : (
        <ul class="note-list">
          {recentNotes.map((note) => (
            <NoteRow note={note} />
          ))}
        </ul>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .site-name {
    font-family: 'Marion', Georgia, serif;
    font-weight: 700;
    font-size: 2.25rem;
    letter-spacing: -0.01em;
  }

  .site-name__owe {
    color: var(--brand-red);
  }

  .site-name__wiki {
    display: inline-block;
    margin-left: 0.35em;
    color: var(--brand-dark-red);
    font-style: italic;
    font-weight: 500;
  }

  .home-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-top: 1rem;
  }

  @media (max-width: 720px) {
    .home-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .domain-list,
  .note-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .domain-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .domain-row a {
    font-family: var(--font-display);
    font-weight: 500;
    text-transform: capitalize;
    text-decoration: none;
    color: var(--color-fg);
  }

  .domain-row a:hover {
    color: var(--color-accent);
  }

  .count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-muted);
  }
</style>
