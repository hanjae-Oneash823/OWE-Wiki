---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import DraftEditor from '../../components/DraftEditor';
import { DOMAINS } from '../../content.config';

const draftId = Astro.params.id as string;
---

<BaseLayout title="Edit draft — Knowledge Wiki">
  <p class="back-link"><a href="/dashboard">&larr; Your drafts</a></p>
  <DraftEditor client:only="react" draftId={draftId} domains={DOMAINS} />
</BaseLayout>

<style>
  .back-link {
    max-width: 92%;
    margin: 0 auto 1rem;
  }
</style>
